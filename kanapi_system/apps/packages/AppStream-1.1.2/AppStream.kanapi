PACKAGE_NAME=AppStream
VER=1.1.2
URL="https://www.freedesktop.org/software/appstream/releases"
EXT=tar.xz
#build depends on
#LIB_DEPENDS=""

. ../settings

#export LDFLAGS="${LDFLAGS} "
#export CFLAGS="${CFLAGS} "

MESON_FLAGS="-Dsystemd=false -Dgir=false"

pkg_configure() {
  local_copy
  if [ -d build ]; then rm -r build; fi
  sed -i "s/subdir('docs\/')//g" meson.build
  mkdir -p build
  meson setup --prefix $PREFIX build ${MESON_FLAGS}
}

pkg_build() {
  cd build
  pkg_build_meson
}

pkg_install() {
  cd build
  pkg_install_all_meson
}
