PACKAGE_NAME=xmessage
VER=1.0.7
URL="https://gitlab.freedesktop.org/xorg/app/xmessage/-/archive/xmessage-${VER}"
EXT=tar.gz
#build depends on
#LIB_DEPENDS=""

. ../settings

#export LDFLAGS="${LDFLAGS} "
#export CFLAGS="${CFLAGS} "

pkg_download() {
  PACKAGE_PATH=xmessage-xmessage-${VER}.${EXT}
  pkg_curl
}

pkg_postprepare() {
  ${LN_SF} ${KANAPI_BUILD_SRC}/xmessage-xmessage-${VER} ${PACKAGE_SRCDIR}
}

pkg_configure() {
  pkg_configure_autoconf
}

pkg_build() {
  pkg_build_local
}

pkg_install() {
  cd build
  pkg_install_all
}
