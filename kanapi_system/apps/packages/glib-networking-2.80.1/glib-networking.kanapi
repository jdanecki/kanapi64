PACKAGE_NAME=glib-networking
VER=2.80.1
URL="https://gitlab.gnome.org/GNOME/glib-networking/-/archive/${VER}"
EXT=tar.bz2
#build depends on
#LIB_DEPENDS="gio-2.0 gmodule-2.0 zlib libffi"

. ../settings

#export PERL5LIB="${KANAPI_BASE}/XML-Parser-${XML_Parser_ver}/lib/site_perl/${perl_ver}"
#export LDFLAGS="${LDFLAGS} -lresolv"

pkg_configure() {
    MESON_FLAGS="-Dlibproxy=disabled"
    pkg_configure_meson
}

pkg_build() {
    pkg_build_meson
}

pkg_install() {
	pkg_install_all_meson
   ${LN_SF} ${PREFIX}/lib/gio/modules/*.so ${KANAPI_BASE}/glib-${glib_ver}/lib/gio/modules
   cp -av ${PREFIX}/lib/gio/modules/giomodule.cache ${KANAPI_BASE}/glib-${glib_ver}/lib/gio/modules

}


