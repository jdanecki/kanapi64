PACKAGE_NAME=snowball
VER=3.0.1
URL="https://github.com/snowballstem/snowball/archive/refs/tags"
EXT=tar.gz
#build depends on
#LIB_DEPENDS=""

. ../settings

#export LDFLAGS="${LDFLAGS} "
#export CFLAGS="${CFLAGS} "

pkg_download() {
  PACKAGE_PATH=v${VER}.${EXT}
  pkg_curl
}

pkg_configure() {
  local_copy
  patch -p1 <../../../packages/${PACKAGE_NAME}-${VER}/0001-Make-libstemmer-a-shared-library.patch
}

pkg_build() {
  pkg_build_local
}

pkg_install() {
  mkdir -p ${PREFIX}/bin &&
    mkdir -p ${PREFIX}/lib &&
    cp -r ./build/include ${PREFIX} &&
    cp ./build/snowball ${PREFIX}/bin &&
    cp ./build/stemwords ${PREFIX}/bin &&
    cp ./build/libstemmer.so.0 ${PREFIX}/lib &&
    cp ./build/libstemmer.so.0 ${PREFIX}/lib/libstemmer.so &&
    pkg_install_bin_all &&
    pkg_install_libs
}
