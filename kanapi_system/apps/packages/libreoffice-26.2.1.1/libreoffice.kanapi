PACKAGE_NAME=libreoffice
VER=26.2.1.1
URL="https://download.documentfoundation.org/libreoffice/src/26.2.1"
EXT=tar.xz
#build depends on
#LIB_DEPENDS=""

. ../settings

#export LDFLAGS="${LDFLAGS} "
#export CFLAGS="${CFLAGS} "

CONFIG_FLAGS="--disable-cups --with-system-curl --with-system-nss --with-system-xmlsec --without-junit" # disabling junit due to java dep
pkg_build() {
  sed -i "s/exit 1;//g" Makefile
  ${MAKE} -j ${MAKE_JOBS} MAKEINFO=true
}

pkg_install() {
  cp -r instdir/* ${PREFIX}

  ${LN_SF} ${PREFIX}/program/soffice ${KANAPI_BIN}
}
