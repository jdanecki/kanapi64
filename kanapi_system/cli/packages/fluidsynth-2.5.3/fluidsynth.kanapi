PACKAGE_NAME=fluidsynth
VER=2.5.3
URL="https://github.com/FluidSynth/fluidsynth/archive/refs/tags"
EXT=tar.gz
#build depends on
LIB_DEPENDS="ncurses"

. ../settings

export LDFLAGS="${LDFLAGS} -lstdc++"
#export CFLAGS="${CFLAGS} "

pkg_download() {
	PACKAGE_PATH=v${VER}.${EXT}
	pkg_curl
}

pkg_configure() {
	pkg_configure_cmake
}

pkg_build() {
	pkg_build_cmake
}

pkg_install() {
	pkg_install_all_cmake
}
